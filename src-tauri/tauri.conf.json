{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DPCrawler",
  "version": "1.0.0",
  "identifier": "com.dpcrawler.app",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": "node ../scripts/build-sidecar.js"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DPCrawler - RAG知识爬虫",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/crawler"
    ]
  }
}
